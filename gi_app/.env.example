# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# ---- PostgreSQL ----
DB_USER=gicancer
DB_PASSWORD=change_me
DB_NAME=gi_cancer_db
# DATABASE_URL is derived from the above in docker-compose; override only if needed.
# DATABASE_URL=postgresql://gicancer:change_me@db:5432/gi_cancer_db

# ---- pgAdmin ----
# The email must use a real domain — pgAdmin rejects reserved ones like .local / .localhost.
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=change_me

# ---- MinIO / object storage (S3-compatible) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
# S3_* is how the Python services reach the store (locally MinIO; on AWS, point at S3).
# S3_ACCESS_KEY must equal MINIO_ROOT_USER and S3_SECRET_KEY must equal MINIO_ROOT_PASSWORD,
# or uploads fail with "SignatureDoesNotMatch".
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me
S3_BUCKET=gi-cancer
# Browser-facing URL used when the API signs MinIO download links.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ---- AWS S3 (optional second download target for the "Add data" tool) ----
# Leave blank to keep MinIO-only (the "AWS S3" destination stays disabled in the UI).
# Fill these in to enable downloading a dataset straight to real S3.
# AWS_S3_ACCESS_KEY=
# AWS_S3_SECRET_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=us-east-1
# AWS_S3_ENDPOINT=   # leave unset for real AWS S3; set only for an S3-compatible endpoint

# ---- Web app (build-time) ----
# The browser calls this URL. Vite inlines it into the static bundle when the app
# image is built, so change it and rebuild (`docker compose build app`) to retarget.
VITE_API_URL=http://localhost:8008

# ---- Container name overrides (optional) ----
CONTAINER_NAME_DB=gi_cancer_db
CONTAINER_NAME_PGADMIN=gi_cancer_pgadmin
CONTAINER_NAME_MINIO=gi_cancer_minio
CONTAINER_NAME_ETL=gi_cancer_etl
CONTAINER_NAME_NOTEBOOK=gi_cancer_notebook
